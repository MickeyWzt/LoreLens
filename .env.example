# Server
PORT=3000

# Vision provider: qwen | gemini
VISION_PROVIDER=qwen
QWEN_API_KEY=
# DASHSCOPE_API_KEY=             # Alias for QWEN_API_KEY
QWEN_VISION_MODEL=qwen-vl-max-latest
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Text provider: deepseek | gemini
TEXT_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_TEXT_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional Gemini primary/fallback provider
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_TEXT_MODEL=gemini-2.5-flash
VISION_FALLBACK_PROVIDER=gemini
TEXT_FALLBACK_PROVIDER=gemini

# Upstream timeout in milliseconds (1000-120000)
AI_TIMEOUT_MS=30000

# Xiaomi MiMo V2.5 cloud read aloud (Chinese and English built-in voices)
MIMO_API_KEY=
MIMO_TTS_MODEL=mimo-v2.5-tts
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TTS_TIMEOUT_MS=30000
MIMO_TTS_VOICE_ZH=茉莉
MIMO_TTS_VOICE_EN=Mia

# Optional remote travel backgrounds
UNSPLASH_ACCESS_KEY=

# Optional server-side IP geolocation endpoint.
# Expected JSON fields: lat/latitude, lng/lon/longitude, and optional city/region/country.
IP_LOCATION_URL=
